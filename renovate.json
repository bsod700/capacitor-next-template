{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchPackagePatterns": ["@capacitor/*"],
      "groupName": "capacitor",
      "automerge": false
    },
    {
      "matchPackagePatterns": ["next", "react", "react-dom"],
      "groupName": "next-react",
      "automerge": false
    }
  ],
  "prHourlyLimit": 2,
  "rangeStrategy": "bump"
}
